# Supabase public browser-safe configuration.
# Fill these in locally in .env.local. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only keys, if introduced in later stories, must not use NEXT_PUBLIC_.
# Do not place Supabase secret or service-role keys in client-accessible vars.

# Upstash Redis (rate limiting). Server-only secrets — do not prefix with
# NEXT_PUBLIC_. When absent, rate limiting fails open (never blocks requests).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry error monitoring.
# Safe client-side: a DSN only permits *writing* events, not reading them.
NEXT_PUBLIC_SENTRY_DSN=
# Server-only secrets, build-time only (used by the Sentry webpack/turbopack
# plugin to upload source maps). Never expose with NEXT_PUBLIC_. The build
# succeeds without these — source-map upload is skipped gracefully instead.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# E2E test suite only (playwright test / npm run test:e2e). Used by
# e2e/global-setup.ts and e2e/global-teardown.ts to create, confirm, and
# delete disposable test users/products/versions -- never read by the app
# itself. MUST be the service-role key of a dev/test Supabase project only
# (matching NEXT_PUBLIC_SUPABASE_URL above) -- never production.
E2E_SUPABASE_SERVICE_ROLE_KEY=

# E2E test suite only. A real mailbox to plus-address disposable test
# signups from (e.g. yourname@gmail.com) -- Supabase rejects reserved/
# example.com-style domains, so the consumer-journey spec builds
# yourname+e2e-<runid>@gmail.com from this for each run.
E2E_SIGNUP_EMAIL_BASE=
